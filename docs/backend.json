
{
  "entities": {
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project, the highest level of organization for tracking costs and progress.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "plannedEndDate": { "type": "string", "format": "date-time" },
        "totalBudgetAmount": { "type": "number" },
        "currentStatus": { "type": "string", "format": "enum" },
        "location": { "type": "string" },
        "responsibleAnalystId": { "type": "string" },
        "marginPercentage": { "type": "number" },
        "adjudicationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "totalBudgetAmount", "currentStatus", "responsibleAnalystId"]
    },
    "GlobalConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GlobalConfig",
      "type": "object",
      "description": "Configuración maestra de variables de costo (UOCRA, ART, Cargas Sociales, etc.)",
      "properties": {
        "uocraBasic": { "type": "number", "description": "Básico hora Oficial" },
        "attendanceBonus": { "type": "number", "default": 20, "description": "Asistencia Perfecta %" },
        "socialCharges": { "type": "number", "default": 24, "description": "Cargas Sociales Empleador %" },
        "fondoCeseL1": { "type": "number", "default": 12, "description": "Fondo Cese 1er Año %" },
        "artPercentage": { "type": "number", "default": 4, "description": "Alícuota ART %" },
        "inactivityFactor": { "type": "number", "default": 15, "description": "Factor Inactividad (Lluvia/Feriados) %" },
        "materialWaste": { "type": "number", "default": 5, "description": "Desperdicio Materiales %" },
        "financialTax": { "type": "number", "default": 2, "description": "Impuestos Déb/Créd %" },
        "contingencyReserve": { "type": "number", "default": 5, "description": "Reserva Contingencia %" },
        "lifeInsurance": { "type": "number", "default": 500, "description": "Seguro de Vida Obligatorio (Fijo)" }
      }
    },
    "Stage": {
      "title": "Stage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "BudgetItem": {
      "title": "BudgetItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "budgetedTotalAmount": { "type": "number" },
        "currentPhysicalProgressPercentage": { "type": "number" },
        "accumulatedActualCost": { "type": "number" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "totalAmount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{userId}/config/global",
        "definition": {
          "entityName": "GlobalConfig",
          "schema": { "$ref": "#/backend/entities/GlobalConfig" },
          "description": "Configuración de constantes de costo para el analista."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": { "$ref": "#/backend/entities/Project" },
          "description": "Proyectos y Licitaciones."
        }
      }
    ]
  }
}
