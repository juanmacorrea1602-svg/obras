
{
  "entities": {
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project or tender, with full financial and technical configuration.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { 
          "type": "string", 
          "enum": ["licitacion_privada", "licitacion_publica", "presupuesto_propio", "cliente_externo"]
        },
        "workType": { "type": "string" },
        "surfaceSqm": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "plannedEndDate": { "type": "string", "format": "date-time" },
        "totalBudgetAmount": { "type": "number" },
        "currentStatus": { 
          "type": "string", 
          "enum": ["PENDIENTE_APROBACION", "LICITACION", "OK", "FINALIZADO", "ALERTA"]
        },
        "location": { "type": "string" },
        "responsibleAnalystId": { "type": "string" },
        "marginPercentage": { "type": "number" },
        "clientId": { "type": "string" }
      }
    },
    "Client": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cuit": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVO", "INACTIVO", "MOROSO"] },
        "currentBalance": { "type": "number" }
      }
    },
    "ClientTransaction": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["FACTURA", "PAGO", "NOTA_CREDITO"] },
        "date": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "reference": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Supplier": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cuit": { "type": "string" },
        "category": { "type": "string", "enum": ["Materiales", "Subcontratista", "Servicios", "Maquinaria"] },
        "currentBalance": { "type": "number" }
      }
    },
    "PaymentOrder": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDIENTE", "PAGADO", "ANULADO"] },
        "paymentMethod": { "type": "string", "enum": ["Efectivo", "Transferencia", "Cheque"] }
      }
    },
    "HRFile": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "dni": { "type": "string" },
        "category": { "type": "string" },
        "entryDate": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVO", "BAJA", "LICENCIA"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/projects/{projectId}",
        "definition": { "entityName": "Project" }
      },
      {
        "path": "/clients/{clientId}",
        "definition": { "entityName": "Client" }
      },
      {
        "path": "/clients/{clientId}/documents/{docId}",
        "definition": { "entityName": "object" }
      },
      {
        "path": "/clients/{clientId}/transactions/{txId}",
        "definition": { "entityName": "ClientTransaction" }
      },
      {
        "path": "/suppliers/{supplierId}",
        "definition": { "entityName": "Supplier" }
      },
      {
        "path": "/payment_orders/{orderId}",
        "definition": { "entityName": "PaymentOrder" }
      },
      {
        "path": "/hr_files/{fileId}",
        "definition": { "entityName": "HRFile" }
      }
    ]
  }
}
